# Application
APP_NAME=VSmartPay AI Support Agent
APP_VERSION=1.0.0
DEBUG=True

# MongoDB
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=vsmartpay_support_agent

# Security
SECRET_KEY=your_secure_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BCRYPT_LOG_ROUNDS=12

# OpenAI & RAG Configs
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_PATH=vector_store/faiss_index
TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=100
VECTOR_STORE=atlas

# Agent
LLM_AGENT_ENABLED=True
LLM_AGENT_FALLBACK_TO_RULES=True
USE_LANGGRAPH=False

# Routing
ROUTING_CONFIDENCE_THRESHOLD=0.6
ROUTING_HIGH_RISK_INTENTS=ACCOUNT_SECURITY,FRAUD_OR_SCAM_REPORT,FAILED_TRANSACTION,REFUND_OR_DISPUTE
ROUTING_DIRECT_ESCALATION_INTENTS=HUMAN_SUPPORT_REQUEST,FRAUD_OR_SCAM_REPORT,ACCOUNT_SECURITY,REFUND_OR_DISPUTE

# API
API_V1_STR=/api/v1

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LangSmith Configuration
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=vsmartpay-ai-support-agent

