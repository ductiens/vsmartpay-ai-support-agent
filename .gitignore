# Project specific data directories
# Ignore all downloaded Kaggle raw data, processed data, and custom samples
data/raw/*
data/processed/*
data/sample/*

# Do not ignore .gitkeep files so the directory structure is preserved in git
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/sample/.gitkeep

